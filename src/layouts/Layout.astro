---
import "@/styles/reset.css"
import "@/styles/fonts.css"
import "@/styles/color.css"
import "@/styles/typography.css"
import "@/styles/typography-headings.css"
import "@/styles/typography-inline.css"
import "@/styles/typography-lists.css"
import "@/styles/typography-block.css"
import "@/styles/typography-tables.css"
import "@/styles/typography-math.css"
import "@/styles/callout.css"
import "@/styles/layout.css"
import "@/styles/icon-button.css"
import "@/styles/bar.css"
import "@/styles/shape.css"

import Footer from "@/components/Footer.astro"
import MetaHead from "@/components/MetaHead.astro"
import Sidebar from "@/components/Sidebar.astro"
import { SITE } from "@/consts"

type Props = { crumbs?: { label: string; href: string }[]; wide?: boolean }

const { crumbs, wide } = Astro.props
---

<html lang={SITE.locale} dir={SITE.dir}>
  <MetaHead>
    <slot name="head" />
  </MetaHead>
  <body>
    <page-shell>
      <page-header>
        <Sidebar crumbs={crumbs}
          ><slot name="actions" slot="actions" /></Sidebar
        >
      </page-header>
      <page-content data-wide={wide || undefined}>
        <main><slot /></main>
        <page-footer><Footer /></page-footer>
      </page-content>
      {Astro.slots.has("toc") && <page-toc><slot name="toc" /></page-toc>}
    </page-shell>

    <script is:inline>
      (() => {
        let lightbox

        const closeLightbox = () => {
          if (!lightbox) return
          lightbox.hidden = true
          document.documentElement.classList.remove("has-lightbox")
        }

        const getLightbox = () => {
          if (lightbox) return lightbox

          lightbox = document.createElement("div")
          lightbox.className = "photo-lightbox"
          lightbox.hidden = true
          lightbox.innerHTML = `
            <div class="photo-lightbox-backdrop"></div>
            <figure>
              <button type="button" aria-label="close image">x</button>
              <img alt="">
              <figcaption></figcaption>
            </figure>
          `

          lightbox.addEventListener("click", (event) => {
            if (
              event.target === lightbox ||
              event.target.classList.contains("photo-lightbox-backdrop") ||
              event.target.closest("button")
            ) {
              closeLightbox()
            }
          })

          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") closeLightbox()
          })

          document.body.append(lightbox)
          return lightbox
        }

        const placeCloseButton = () => {
          if (!lightbox || lightbox.hidden) return

          const modalImage = lightbox.querySelector("img")
          const closeButton = lightbox.querySelector("button")
          const imageRect = modalImage.getBoundingClientRect()
          closeButton.style.setProperty(
            "--close-left",
            `${Math.min(imageRect.right + 6, window.innerWidth - 42)}px`,
          )
          closeButton.style.setProperty(
            "--close-top",
            `${Math.max(imageRect.top, 8)}px`,
          )
        }

        document.addEventListener("click", (event) => {
          const target = event.target
          if (!(target instanceof Element)) return

          const link = target.closest(".photo-gallery a")
          if (!link) return

          const image = link.querySelector("img")
          const caption = link.querySelector("span")
          if (!image) return

          event.preventDefault()

          const modal = getLightbox()
          const modalFigure = modal.querySelector("figure")
          const modalImage = modal.querySelector("img")
          const modalCaption = modal.querySelector("figcaption")
          const imageRect = image.getBoundingClientRect()
          const imageAspect = image.naturalWidth / image.naturalHeight
          const maxLightboxWidth = Math.min(window.innerWidth * 0.92, 992)
          const maxLightboxImageHeight = window.innerHeight * 0.88 - 40
          const lightboxWidth = Math.min(
            maxLightboxWidth,
            maxLightboxImageHeight * imageAspect,
          )

          modalImage.src = link.href
          modalImage.alt = image.alt
          modalCaption.textContent = caption?.textContent || image.alt
          modalFigure.style.setProperty("--thumb-top", `${imageRect.top}px`)
          modalFigure.style.setProperty("--thumb-left", `${imageRect.left}px`)
          modalFigure.style.setProperty("--thumb-width", `${imageRect.width}px`)
          modalFigure.style.setProperty("--thumb-height", `${imageRect.height}px`)
          modalFigure.style.setProperty("--lightbox-width", `${lightboxWidth}px`)
          modal.hidden = false
          document.documentElement.classList.add("has-lightbox")

          modalImage.addEventListener("load", placeCloseButton, { once: true })
          setTimeout(placeCloseButton, 220)
        })

        window.addEventListener("resize", placeCloseButton)
      })()
    </script>
  </body>
</html>

<style>
  page-shell {
    display: flex;
    flex-direction: column;
    min-height: 100svh;
  }

  page-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-block-end: 2px solid var(--border);
    background-color: color-mix(in oklab, var(--background) 92%, transparent);
    backdrop-filter: blur(var(--blur-sm));
  }

  page-content {
    display: flex;
    flex: 1;
    flex-direction: column;
    width: min(100%, var(--measure));
    margin-inline: auto;
    padding-inline: var(--space-s-m);
    padding-block-start: var(--space-xl);

    main {
      flex: 1;
    }

    page-footer {
      display: block;
      margin-block-start: var(--space-xl);
    }
  }

  page-content[data-wide] {
    width: min(100%, 48rem);
    padding-block-start: var(--space-l);
  }

  page-content[data-wide] page-footer {
    margin-block-start: var(--space-l);
  }

  page-toc {
    display: none;
  }

  @media (min-width: 76rem) {
    page-toc {
      display: block;
      position: fixed;
      inset-block: calc(3.5rem + var(--space-l)) var(--space-l);
      inset-inline-start: calc(50% + 22rem);
      width: 14rem;
    }

    page-toc :global(nav) {
      position: static;
      max-height: 100%;
    }
  }

  :global(html.has-lightbox) {
    overflow: hidden;
  }

  :global(.photo-lightbox) {
    position: fixed;
    z-index: 50;
    inset: 0;
    background-color: transparent;
  }

  :global(.photo-lightbox[hidden]) {
    display: none;
  }

  :global(.photo-lightbox-backdrop) {
    position: absolute;
    inset: 0;
    background-color: color-mix(in oklab, black 82%, transparent);
  }

  :global(.photo-lightbox button) {
    position: absolute;
    z-index: 1;
    inset-block-start: var(--close-top, var(--space-s));
    inset-inline-start: var(--close-left, auto);
    display: grid;
    width: 2.25rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid color-mix(in oklab, white 32%, transparent);
    border-radius: var(--radius-sm);
    background-color: color-mix(in oklab, black 50%, transparent);
    color: white;
    font: inherit;
    line-height: 1;
    cursor: pointer;
  }

  :global(.photo-lightbox figure) {
    position: absolute;
    inset-block-start: var(--thumb-top);
    inset-inline-start: var(--thumb-left);
    display: flex;
    width: var(--thumb-width);
    min-height: var(--thumb-height);
    flex-direction: column;
    gap: var(--space-2xs);
    margin: 0;
    animation: photo-lightbox-pop 180ms ease-out forwards;
  }

  :global(.photo-lightbox img) {
    width: 100%;
    max-height: calc(88svh - 2.5rem);
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: 0 1rem 4rem color-mix(in oklab, black 45%, transparent);
  }

  :global(.photo-lightbox figcaption) {
    color: white;
    font-size: var(--step--1);
    text-align: center;
  }

  @keyframes photo-lightbox-pop {
    to {
      inset-block-start: 50%;
      inset-inline-start: 50%;
      width: var(--lightbox-width);
      min-height: 0;
      transform: translate(-50%, -50%);
    }
  }
</style>
